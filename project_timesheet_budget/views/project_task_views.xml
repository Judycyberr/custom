<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="project_task_form_view" model="ir.ui.view">
        <field name="name">Project Task</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="hr_timesheet.view_task_form2_inherited"/>
        <field name="arch" type="xml">
<!--            <xpath expr="//field[@name='timesheet_ids']/list" position="inside">-->
<!--                <field name="total_time_sheet" string="Total"/>-->
<!--            </xpath>-->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="total_net" string="Total expense"/>
            </xpath>
        </field>
    </record>

    <record id="project_task" model="ir.actions.act_window">
        <field name="name">Project Task</field>
        <field name="res_model">project.task</field>
        <field name="views">form,list</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

</odoo>