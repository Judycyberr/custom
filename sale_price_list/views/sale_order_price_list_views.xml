<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_price_list_form_view" model="ir.ui.view">
        <field name="name">Sale Order Price List</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pricelist_id']" position="after">
                <field name="price_list_id" string="New price list"/>
            </xpath>
        </field>
    </record>

    <record id="sale_order_price_list" model="ir.actions.act_window">
        <field name="name">Price List</field>
        <field name="res_model">sale.order</field>
        <field name="views">form,list</field>
        <field name="view_mode">list,kanban,form</field>
    </record>
</odoo>