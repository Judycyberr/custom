<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_project_task_form_view" model="ir.ui.view">
        <field name="name">Project Task</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
               <button class="oe_stat_button" name="action_view_sale_order" type="object" icon="fa-pencil-square-o">
                   Sale-order
               </button>
            </xpath>
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="sale_order_id" context="{'task_ids': id}"/>
            </xpath>
<!--            <field name="sale_order_id"/>-->
        </field>
    </record>

    <record id="sale_project_task" model="ir.actions.act_window">
        <field name="name">Project Task</field>
        <field name="res_model">project.task</field>
        <field name="views">form,list</field>
        <field name="view_mode">list,kanban,form</field>
    </record>
</odoo>