<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hotel_food_items_wizard" model="ir.ui.view">
        <field name="name">Hotel Food Item Wizard</field>
        <field name="model">hotel.food.items.wizard</field>
        <field name="arch" type="xml">
            <form string="Open Wizard">
                <group>
                    <field name="image" widget="image" options="{'size': [150, 150]}"/>
                    <group>
                        <field name="name" style="font-size:15pt;"/>
                        <field name="item"/>
                        <field name="category_id"/>
                    </group>
                    <group>

                        <field name="price"/>
                        <field name="description"/>
                    </group>
                </group>
                <footer>
                   <button string="Add to list" name="add_to_list" type="object" class="btn-primary"/>
                   <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="hotel_food_items_wizard" model="ir.actions.act_window">
        <field name="name">Food Items</field>
        <field name="res_model">hotel.food.items.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>