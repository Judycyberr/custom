<?xml version="1.0" encoding="utf-8"?>
<odoo>
   <data>
       <record model="ir.module.category" id="module_category_hotel_management">
           <field name="name">hotel</field>
           <field name="sequence">5</field>
       </record>
       <record model="res.groups.privilege" id="res_groups_privilege_hotel">
           <field name="name">Hotel Management</field>
           <field name="category_id" ref="hotel_management.module_category_hotel_management"/>
       </record>
       <!-- hotel user group-->
       <record id="group_hotel_reception" model="res.groups">
           <field name="name">Receptionist</field>
           <field name="privilege_id" ref="res_groups_privilege_hotel" />
           <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
       </record>
       <record id="group_hotel_manager" model="res.groups">
           <field name="name">Manager</field>
           <field name="privilege_id" ref="res_groups_privilege_hotel" />
           <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
       </record>
       <!-- hotel manager group-->
       <record id="group_hotel_admin" model="res.groups">
           <field name="name">Admin</field>
           <field name="privilege_id" ref="res_groups_privilege_hotel" />
           <field name="implied_ids" eval="[(4, ref('group_hotel_reception')),(4, ref('group_hotel_manager'))]" />
           <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]" />
       </record>
   </data>
</odoo>
