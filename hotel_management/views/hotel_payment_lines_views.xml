<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hotel_payment_lines_list_view" model="ir.ui.view">
        <field name="name">Payment Lines</field>
        <field name="model">hotel.payment.lines</field>
        <field name="arch" type="xml">
            <list string="List" editable="bottom">
                    <field name="product_id"/>
                    <field name="price"/>
            </list>
        </field>
    </record>

    <record id="hotel_payment_lines" model="ir.actions.act_window">
        <field name="name">Payment Lines</field>
        <field name="res_model">hotel.payment.lines</field>
        <field name="views">form,list</field>
    </record>
</odoo>