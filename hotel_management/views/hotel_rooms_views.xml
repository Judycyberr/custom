<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="rooms_list_view" model="ir.ui.view">
        <field name="name">Rooms</field>
        <field name="model">hotel.rooms</field>
        <field name="arch" type="xml">
            <list string="List">
                <field name="room_no"/>
                <field name="bed"/>
                <field name="available_beds"/>
                <field name="rent"/>
                <field name="facility_ids" widget="many2many_tags"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="rooms_form_view" model="ir.ui.view">
        <field name="name">Rooms</field>
        <field name="model">hotel.rooms</field>
        <field name="arch" type="xml">
                <form string="form">
                    <sheet>
                        <group>
                            <h1>
                                <group>
                                    <field name="room_no"/>
                                </group>
                            </h1>
                            <group>
                                <field name="bed"/>
                                <field name="available_beds" invisible="bed!='dormitory'"/>
                                <field name="rent"/>
                                <field name="facility_ids" widget="many2many_tags"/>
                                <field name="state"/>
                            </group>
                        </group>
                    </sheet>
                </form>
        </field>
    </record>
    <record id="rooms_search_view" model="ir.ui.view">
        <field name="name">Rooms</field>
        <field name="model">hotel.rooms</field>
        <field name="arch" type="xml">
            <search string="Bed Type">
                <field name="room_no"/>
                <field name="bed"/>
                <field name="available_beds"/>
                <field name="rent"/>
                <field name="facility_ids"/>
                <field name="state"/>
                <filter string="Available" name="state" domain="[('state', '=', 'available')]"/>
                <filter string="Bed Type" name="bed" context="{'group_by':'bed'}"/>
                <filter string="Facility" name="facility_ids" context="{'group_by':'facility_ids'}"/>
            </search>
        </field>
    </record>

    <record id="rooms_action" model="ir.actions.act_window">
        <field name="name">Rooms</field>
        <field name="res_model">hotel.rooms</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>