<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_order_list_list_view" model="ir.ui.view">
        <field name="name">Guest</field>
        <field name="model">hotel.order.list</field>
        <field name="arch" type="xml">
            <list string="List" create="0">
                <field name="name"/>
                <field name="price"/>
                <field name="order_id"/>
                <field name="quantity"/>
            </list>
        </field>
    </record>

    <record id="hotel_order_list" model="ir.actions.act_window">
        <field name="name">Hotel Order List</field>
        <field name="res_model">hotel.order.list</field>
        <field name="views">form,list</field>
    </record>
</odoo>
