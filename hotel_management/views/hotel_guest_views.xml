<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_guest_form_view" model="ir.ui.view">
        <field name="name">Guest</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
                <xpath expr="//field[@name='category_id']" position="after">
                        <field name="gender"/>
                        <field name="age"/>
                        <field name="is_hotel_guest"/>
                        <field name="accommodation_id"/>
                </xpath>
        </field>
    </record>

    <record id="hotel_guest_search_view" model="ir.ui.view">
        <field name="name">Guest</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
             <xpath expr="//search/group" position="inside">
                <filter string="Guest" name="guest" domain="[('is_hotel_guest', '=', True)]"/>
             </xpath>
        </field>
    </record>

    <record id="hotel_guest" model="ir.actions.act_window">
        <field name="name">Guest</field>
        <field name="res_model">res.partner</field>
        <field name="views">form,list</field>
        <field name="context">{'default_is_hotel_guest': 1,'search_default_guest': 1}</field>
    </record>
</odoo>